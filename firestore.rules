rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - role: string (admin/user)
    //   - totalPoints: number
    //   - totalMargin: number
    //   - unlockedRounds: list (numbers)
    //
    // Collection: public_profiles
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - role: string
    //   - totalPoints: number
    //   - totalMargin: number
    //
    // Collection: teams
    // Fields:
    //   - id: number (required)
    //   - name: string
    //   - abbrev: string
    //   - logo: string
    //
    // Collection: games
    // Fields:
    //   - id: number (required)
    //   - round: number
    //   - winner: string
    //   - isFinished: bool
    //   ... (Squiggle API fields)
    //
    // Collection: tips
    // Fields:
    //   - uid: string (required)
    //   - gameId: number (required)
    //   - round: number
    //   - selectedTeam: string
    //   - margin: number (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == "acaback@gmail.com"
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100 &&
             data.role in ['admin', 'user'];
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role']) &&
             data.uid is string &&
             data.displayName is string &&
             data.displayName.size() < 100 &&
             data.role in ['admin', 'user'];
    }

    function isValidTeam(data) {
      return data.keys().hasAll(['id', 'name', 'abbrev']) &&
             data.id is number &&
             data.name is string &&
             data.name.size() < 100 &&
             data.abbrev is string &&
             data.abbrev.size() < 10;
    }

    function isValidTip(data) {
      return data.keys().hasAll(['uid', 'gameId', 'round', 'selectedTeam']) &&
             data.gameId is number &&
             data.round is number &&
             data.selectedTeam is string &&
             (!('margin' in data) || data.margin is number);
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isAuthenticated() && request.query.filters.email == request.auth.token.email);
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
      allow delete: if isAdmin();
    }

    match /public_profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidPublicProfile(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidPublicProfile(request.resource.data));
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidTeam(request.resource.data);
    }

    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tips/{tipId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTip(request.resource.data) && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.uid == request.auth.uid && 
        isValidTip(request.resource.data) &&
        request.resource.data.uid == resource.data.uid
      );
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }
  }
}
