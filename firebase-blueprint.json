{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and tipping statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "totalPoints": { "type": "number" },
        "totalMargin": { "type": "number" },
        "unlockedRounds": { "type": "array", "items": { "type": "number" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Game": {
      "title": "Game",
      "description": "AFL game data cached from Squiggle",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "round": { "type": "number" },
        "year": { "type": "number" },
        "hometeam": { "type": "string" },
        "awayteam": { "type": "string" },
        "date": { "type": "string" },
        "venue": { "type": "string" },
        "winner": { "type": "string" },
        "hscore": { "type": "number" },
        "ascore": { "type": "number" },
        "isFirstInRound": { "type": "boolean" },
        "isFinished": { "type": "boolean" }
      },
      "required": ["id", "round", "hometeam", "awayteam", "date"]
    },
    "Tip": {
      "title": "Tip",
      "description": "A user's tip for a specific game",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "gameId": { "type": "number" },
        "round": { "type": "number" },
        "selectedTeam": { "type": "string" },
        "margin": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "gameId", "round", "selectedTeam"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Non-sensitive user profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "totalPoints": { "type": "number" },
        "totalMargin": { "type": "number" },
        "favoriteTeam": { "type": "string" }
      },
      "required": ["uid", "displayName", "role"]
    },
    "Team": {
      "title": "Team",
      "description": "AFL Team data",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "abbrev": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["id", "name", "abbrev"]
    },
    "Message": {
      "title": "Message",
      "description": "User comments on the message board",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "displayName", "text", "createdAt"]
    },
    "PollVote": {
      "title": "Poll Vote",
      "description": "User vote on game winner poll",
      "type": "object",
      "properties": {
        "gameId": { "type": "number" },
        "uid": { "type": "string" },
        "vote": { "type": "string", "enum": ["home", "away"] },
        "round": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["gameId", "uid", "vote", "round", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/public_profiles/{uid}": {
      "schema": "PublicProfile",
      "description": "Public user profiles"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "AFL Teams"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Cached AFL games"
    },
    "/tips/{tipId}": {
      "schema": "Tip",
      "description": "User tips (tipId is usually uid_gameId)"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Message board posts"
    },
    "/poll_votes/{voteId}": {
      "schema": "PollVote",
      "description": "Community poll votes"
    }
  }
}
